# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# Supabase (same project as frontend)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# IMPORTANT: this is the SERVICE ROLE key, not the anon key.
# It bypasses Row Level Security — never expose it to the frontend.
# Find it in Supabase dashboard: Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
